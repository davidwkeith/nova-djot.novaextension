{
    "identifier": "io.dwk.djot",
    "name": "Djot",
    "organization": "dwk",
    "description": "Djot markup language support with syntax highlighting, code folding, symbol navigation, language server, and live preview.",
    "version": "1.1.0",
    "categories": ["languages"],
    "license": "MIT",
    "main": "main.js",
    "activationEvents": [
        "*"
    ],
    "entitlements": {
        "process": true
    },
    "commands": {
        "editor": [
            {
                "title": "Preview Djot",
                "command": "io.dwk.djot.preview",
                "shortcut": "cmd-shift-p",
                "when": "editorSyntax == 'djot'"
            },
            {
                "title": "Toggle Emphasis",
                "command": "io.dwk.djot.toggleEmphasis",
                "when": "editorSyntax == 'djot'"
            },
            {
                "title": "Toggle Strong",
                "command": "io.dwk.djot.toggleStrong",
                "when": "editorSyntax == 'djot'"
            },
            {
                "title": "Toggle Inline Code",
                "command": "io.dwk.djot.toggleInlineCode",
                "when": "editorSyntax == 'djot'"
            },
            {
                "title": "Toggle Highlight",
                "command": "io.dwk.djot.toggleHighlight",
                "when": "editorSyntax == 'djot'"
            }
        ],
        "extensions": [
            {
                "title": "Preview Djot",
                "command": "io.dwk.djot.preview"
            },
            {
                "title": "Toggle Emphasis",
                "command": "io.dwk.djot.toggleEmphasis"
            },
            {
                "title": "Toggle Strong",
                "command": "io.dwk.djot.toggleStrong"
            },
            {
                "title": "Toggle Inline Code",
                "command": "io.dwk.djot.toggleInlineCode"
            },
            {
                "title": "Toggle Highlight",
                "command": "io.dwk.djot.toggleHighlight"
            }
        ]
    }
}
