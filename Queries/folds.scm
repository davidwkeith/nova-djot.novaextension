; Sections fold as heading + all content until next same-or-higher heading
(section) @fold

; Fenced code and raw blocks
(code_block) @fold
(raw_block) @fold

; Lists (bullet, ordered, task, definition)
(list) @fold

; Fenced div containers
(div) @fold

; Block quotations
(block_quote) @fold

; Tables
(table) @fold

; Footnote definitions
(footnote) @fold
